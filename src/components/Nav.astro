---
const navLinks = [
  { href: '/#inicio', label: 'Inicio' },
  { href: '/#nosotros', label: 'Nosotros' },
  { href: '/#galeria', label: 'Galería' },
  { href: '/#eventos', label: 'Eventos' },
  { href: '/#ubicacion', label: 'Dónde estamos' },
];
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="flex items-center justify-between px-6 py-3 max-w-screen-xl mx-auto">

    <a href="/" aria-label="1592 Quince Noventa Y Dos — Inicio">
      <img
        src="logo.jpeg"
        alt="1592 Quince Noventa Y Dos"
        class="h-12 w-auto"
        style="mix-blend-mode: screen;"
      />
    </a>

    <ul class="hidden md:flex gap-8 items-center">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="text-xs uppercase tracking-widest text-[var(--color-on-surface)] hover:text-[var(--color-gold)] transition-colors duration-300"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <span class="menu-line block w-6 h-0.5 bg-[var(--color-on-surface)]"></span>
      <span class="menu-line block w-6 h-0.5 bg-[var(--color-on-surface)]"></span>
      <span class="menu-line block w-6 h-0.5 bg-[var(--color-on-surface)]"></span>
    </button>
  </nav>

  <div id="mobile-menu" class="md:hidden overflow-hidden">
    <ul class="flex flex-col px-6 pb-6 pt-2 bg-[var(--color-surface)]/95 backdrop-blur-md">
      {navLinks.map((link, i) => (
        <li class="menu-item border-b border-[var(--color-gold)]/10 last:border-b-0">
          <a
            href={link.href}
            class="block py-4 text-xs uppercase tracking-widest text-[var(--color-on-surface)] hover:text-[var(--color-gold)] transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const mobileBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
  const lines = mobileBtn?.querySelectorAll<HTMLElement>('.menu-line');
  const items = mobileMenu?.querySelectorAll<HTMLElement>('.menu-item');

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    mobileBtn?.setAttribute('aria-expanded', 'true');
    mobileBtn?.setAttribute('aria-label', 'Cerrar menú de navegación');

    if (mobileMenu) {
      mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
      mobileMenu.style.opacity = '1';
    }

    if (lines && lines.length >= 3) {
      lines[0].style.transform = 'translateY(8px) rotate(45deg)';
      lines[1].style.opacity = '0';
      lines[1].style.transform = 'scaleX(0)';
      lines[2].style.transform = 'translateY(-8px) rotate(-45deg)';
    }

    items?.forEach((item, i) => {
      item.style.opacity = '0';
      item.style.transform = 'translateX(-10px)';
      item.style.transition = 'none';
      requestAnimationFrame(() => {
        item.style.transition = `opacity 0.3s ease ${i * 70 + 80}ms, transform 0.3s ease ${i * 70 + 80}ms`;
        item.style.opacity = '1';
        item.style.transform = 'translateX(0)';
      });
    });
  }

  function closeMenu() {
    isOpen = false;
    mobileBtn?.setAttribute('aria-expanded', 'false');
    mobileBtn?.setAttribute('aria-label', 'Abrir menú de navegación');

    if (mobileMenu) {
      mobileMenu.style.maxHeight = '0';
      mobileMenu.style.opacity = '0';
    }

    if (lines && lines.length >= 3) {
      lines[0].style.transform = '';
      lines[1].style.opacity = '1';
      lines[1].style.transform = '';
      lines[2].style.transform = '';
    }

    items?.forEach(item => {
      item.style.transition = '';
      item.style.opacity = '';
      item.style.transform = '';
    });
  }

  mobileBtn?.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()));

  mobileMenu?.querySelectorAll('a').forEach(link =>
    link.addEventListener('click', closeMenu)
  );
</script>

<style>
  #main-nav {
    background: #010101;
    border-bottom: 1px solid color-mix(in srgb, var(--color-gold) 15%, transparent);
  }

  #mobile-menu {
    max-height: 0;
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.35s ease;
  }

  .menu-line {
    transform-origin: center;
    transition: transform 0.35s ease, opacity 0.25s ease;
  }
</style>
