---
import { Image } from 'astro:assets';
import happyHourImg from '../assets/images/events-happy-hour.jpeg';
import djImg from '../assets/images/events-dj.jpeg';
import outdoorImg from '../assets/images/events-outdoor.jpeg';

import { eventos } from '../data/events';

const images = [happyHourImg, outdoorImg, djImg];
---

<section id="eventos" class="section-padding bg-[var(--color-wine-dark)] px-6 relative overflow-hidden">

  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--color-wine)_0%,_transparent_60%)] opacity-40 pointer-events-none"></div>

  <div class="max-w-screen-xl mx-auto relative z-10">

    <div class="text-center mb-16 fade-up">
      <p class="text-[var(--color-gold)] text-xs uppercase tracking-[0.5em] mb-5">Viví La Experiencia</p>
      <h2 class="heading-xl text-white">Eventos</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {eventos.map((evento, i) => (
        <div
          class="group rounded-[var(--radius)] overflow-hidden bg-[var(--color-wine)] fade-up"
          style={`transition-delay: ${i * 0.15}s;`}
        >
          <div class="aspect-[4/3] overflow-hidden">
            <Image
              src={images[i]!}
              alt={evento.titulo}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-107 transition-transform duration-700"
            />
          </div>
          <div class="p-6 lg:p-7">
            <div class="flex items-baseline gap-2 mb-3">
              <span class="text-[var(--color-gold)] text-xs uppercase tracking-widest">{evento.dias}</span>
              <span class="text-white/40 text-xs">·</span>
              <span class="text-white/60 text-xs">{evento.horario}</span>
            </div>
            <h3 class="heading-md text-white mb-3">{evento.titulo}</h3>
            <p class="text-white/65 text-sm leading-relaxed">{evento.descripcion}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
